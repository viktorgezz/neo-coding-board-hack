# SQLite по умолчанию в settings; для PostgreSQL:
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/neo_analytics

# OAuth GigaChat: Base64 от строки "<client_id>:<client_secret>"
GIGACHAT_AUTH_KEY=

# RSA public key PEM (same as core-service keys/public_key.pem); Docker: /app/keys/public_key.pem
JWT_PUBLIC_KEY_PATH=keys/public_key.pem
