# Локальный dev (Vite): см. vite.config.ts — прокси /api, /tasks-api, /analytics-api.
# Docker: nginx на фронте проксирует те же префиксы; WebSocket — на тот же хост/порт, что и UI.

VITE_ANALYTICS_API_BASE_URL=/analytics-api
VITE_TASKS_BANK_API_BASE_URL=/tasks-api
VITE_CURSOR_WS_BASE_URL=ws://localhost:3080/cursor-ws
VITE_CODE_WS_BASE_URL=ws://localhost:3080/code-ws
