# Скопируйте в `.env` в корне репозитория (рядом с docker-compose.yml),
# чтобы подставлять переменные при `docker compose up`.

# Порт SPA (nginx)
FRONTEND_PORT=3080

# CORS / security.origin.frontend в core-service — должен совпадать с URL, с которого открывают UI
FRONTEND_ORIGIN=http://localhost:3080

# WebSocket курсора и кода идут через nginx фронта (тот же порт, что и FRONTEND_PORT).
# Меняете FRONTEND_PORT — пересоберите frontend: docker compose build --no-cache frontend
# VITE_CURSOR_WS_BASE_URL=ws://localhost:3080/cursor-ws
# VITE_CODE_WS_BASE_URL=ws://localhost:3080/code-ws

# GigaChat для /ai-summary: задайте в AnaliticsService/.env как GIGACHAT_AUTH_KEY=... (compose подключает этот файл).
# Либо продублируйте здесь и добавьте в analytics-service в docker-compose.yml строку:
# GIGACHAT_AUTH_KEY: ${GIGACHAT_AUTH_KEY}
